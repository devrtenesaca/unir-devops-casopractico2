{
    "name": "FIFA 2026 Web App",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylint"
            ]
        }
    },
    "forwardPorts": [5000],
    "postCreateCommand": "pip install -r requirements.txt",
    "remoteUser": "vscode"
}